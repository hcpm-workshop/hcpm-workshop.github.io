---
import { menuLinks, siteConfig } from "@/site.config";

const year = new Date().getFullYear();

const labLogos = [
	{
		name: "CARE Lab",
		href: "https://carelab.info/",
		src: "https://carelab.info/wp-content/uploads/2017/03/CARElogo_symbolmark-300x241.png",
		square: false,
	},
	{
		name: "Interactive Media Design Lab (IMD Lab)",
		href: "https://imdl.naist.jp/",
		src: "https://imdl.naist.jp/wp-content/uploads/2020/04/logo_without_nickname.png",
		square: false,
	},
	{
		name: "LAVIS Lab",
		href: null,
		src: "https://avatars.githubusercontent.com/u/77007656?s=280&v=4",
		square: true,
	},
];
---

<footer class="text-muted mt-auto flex w-full flex-col items-center pb-4 pt-20 font-semibold">
	<!-- ── LAB LOGOS ─────────────────────────────────────────────────── -->
	<div class="border-muted mb-6 flex w-full flex-wrap items-center justify-center gap-8 border-t pt-8">
		{
			labLogos.map(({ name, href, src, square }) => {
				const img = (
					<img
						src={src}
						alt={name}
						height="48"
						class={`h-12 w-auto object-contain opacity-60 transition-opacity hover:opacity-90 ${square ? "rounded" : ""}`}
					/>
				);
				return href ? (
					<a href={href} target="_blank" rel="noreferrer noopener" aria-label={name}>
						{img}
					</a>
				) : (
					<span aria-label={name}>{img}</span>
				);
			})
		}
	</div>

	<!-- ── COPYRIGHT / NAV ───────────────────────────────────────────── -->
	<div
		class="flex w-full flex-col items-center justify-center gap-y-2 text-center align-top text-xs sm:flex-row sm:justify-between"
	>
		<div class="me-0 sm:me-4">
			&copy; {siteConfig.author}
			{year}.
		</div>
		<nav aria-labelledby="footer_links" class="sm:divide-muted flex gap-x-2 sm:gap-x-0 sm:divide-x">
			<p id="footer_links" class="sr-only">More on this site</p>
			{
				menuLinks.map((link) => (
					<a class="hover:text-global-text px-4 py-2 hover:underline sm:py-0" href={link.path}>
						{link.title}
					</a>
				))
			}
		</nav>
	</div>
</footer>
