---
import PageLayout from "@/layouts/Base.astro";

const stages = [
	{
		num: "01",
		title: "Expert Input",
		text: "Researchers from Germany and Japan introduce key topics in XR, perception, AI, and robotics.",
	},
	{
		num: "02",
		title: "Research Ideation",
		text: "In a cross-cultural team: identify a research question, review literature, scope an approach.",
	},
	{
		num: "03",
		title: "Prototype & Test",
		text: "Build and refine an experiment or prototype with peer and faculty feedback.",
	},
	{
		num: "04",
		title: "Share & Go Further",
		text: "Present results on the final day. Promising projects may continue towards future publications.",
	},
];
---

<PageLayout
	meta={{
		title: "Home",
		description:
			"1st German-Japanese Summer School on Human-Centred Perception Modelling in XR, 14–18 September 2026 at NAIST, Nara, Japan.",
	}}
>
	<!-- ── HERO ──────────────────────────────────────────────────────────── -->
	<!--
		Hero image: NAIST main entrance (official NAIST photo).
		To use your own photo: upload to /public/images/hero.jpg and change src to "/images/hero.jpg"
		-mt-4 cancels the header mb-4 so the image sits flush against the nav.
	-->
	<section class="-mx-4 sm:-mx-8 -mt-4 relative mb-14 overflow-hidden">
		<img
			src="https://www.naist.jp/en/toppage-banner/img/main_entrance.png"
			alt="NAIST main entrance, Ikoma, Nara"
			width="1280"
			height="420"
			class="w-full object-cover"
			style="height: 420px; object-position: center 60%;"
		/>
		<div
			class="absolute inset-0 flex items-end"
			style="background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.22) 55%, rgba(0,0,0,0.06) 100%);"
		>
			<div class="w-full p-6 sm:p-10">
				<p class="mb-2 font-mono text-xs uppercase tracking-widest text-white/60">
					14–18 September 2026, NAIST, Nara, Japan
				</p>
				<h1 class="mb-1 text-2xl font-bold leading-snug text-white sm:text-3xl">
					1st German-Japanese Summer School
				</h1>
				<p class="text-base font-semibold text-white/90 sm:text-xl">
					Human-Centred Perception Modelling in XR
				</p>
			</div>
		</div>
	</section>

	<!-- ── ABOUT ─────────────────────────────────────────────────────────── -->
	<section class="mb-14">
		<p class="leading-relaxed">
			A five-day intensive research workshop bringing together Master's and PhD students from Japan
			and Germany to explore cutting-edge topics in extended reality, perception modelling, and AI.
			Hosted by CARE Lab and IMD Lab at NAIST in collaboration with the LAVIS Lab at HSRM, Germany.
		</p>
		<p class="text-muted mt-3 text-sm">
			Participation is free of charge. Enquiries: <a
				class="cactus-link"
				href="mailto:marquardt@ieee.org">marquardt@ieee.org</a
			>
		</p>
	</section>

	<!-- ── PROGRAMME STAGES ──────────────────────────────────────────────── -->
	<section class="mb-14">
		<h2 class="title mb-6 text-xl">The Programme</h2>
		<div class="grid gap-3 sm:grid-cols-2">
			{
				stages.map(({ num, title, text }) => (
					<div class="border-muted rounded border p-4">
						<p class="text-accent mb-1 font-mono text-xs font-semibold">{num}</p>
						<h3 class="text-accent-2 mb-1 font-semibold">{title}</h3>
						<p class="text-muted text-sm leading-relaxed">{text}</p>
					</div>
				))
			}
		</div>
		<p class="mt-4 text-sm">
			<a class="cactus-link" href="/programme/">Full schedule and venue information</a>
		</p>
	</section>

	<!-- ── LECTURE TOPICS ────────────────────────────────────────────────── -->
	<section class="mb-14">
		<h2 class="title mb-3 text-xl">Lecture Topics</h2>
		<p class="text-muted text-sm leading-relaxed">
			Visual Attention Modelling and Metrics, Multisensory Perception and Integration, Perceptual
			Vision Augmentation, AI Methods for Perception Research, Human-Robot Interaction
		</p>
	</section>

	<!-- ── EVENT POSTER ──────────────────────────────────────────────────── -->
	<!--
		To activate: export the poster as PDF, upload to /public/hcpm-summer-school-2026-poster.pdf
		Then replace the paragraph below with:
		<a class="cactus-link font-semibold" href="/hcpm-summer-school-2026-poster.pdf" download>Download event poster (PDF)</a>
	-->
	<section class="mb-14">
		<h2 class="title mb-3 text-xl">Event Poster</h2>
		<p class="text-muted text-sm">The event poster will be available for download here soon.</p>
	</section>

	<!-- ── PARTNERS ──────────────────────────────────────────────────────── -->
	<section class="text-muted mb-6 text-sm">
		<p class="leading-relaxed">
			Hosted by <strong class="text-global-text">CARE Lab and IMD Lab</strong> at Nara Institute of
			Science and Technology (NAIST), Japan, in collaboration with
			<strong class="text-global-text">LAVIS Lab</strong> at Hochschule RheinMain (HSRM), Germany.
		</p>
	</section>
</PageLayout>
