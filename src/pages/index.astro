---
import PageLayout from "@/layouts/Base.astro";

const stages = [
	{
		num: "01",
		title: "Expert Input",
		text: "Researchers from Germany and Japan introduce key topics in XR, perception, AI, and robotics.",
	},
	{
		num: "02",
		title: "Research Ideation",
		text: "In a cross-cultural team: identify a research question, review literature, scope an approach.",
	},
	{
		num: "03",
		title: "Prototype & Test",
		text: "Build and refine an experiment or prototype with peer and faculty feedback.",
	},
	{
		num: "04",
		title: "Share & Go Further",
		text: "Present results on the final day. Promising projects may continue towards future publications.",
	},
];

const topics = [
	"Visual Attention Modelling",
	"Multisensory Perception",
	"Perceptual Vision Augmentation",
	"AI Methods for Perception",
	"Human-Robot Interaction",
];
---

<PageLayout
	meta={{
		title: "Home",
		description:
			"1st German-Japanese Summer School on Human-Centred Perception Modelling in XR — 14–18 September 2026 at NAIST, Nara, Japan.",
	}}
>
	<!-- ── HERO ──────────────────────────────────────────────────────────── -->
	<!--
		Hero image: Kasuga Taisha shrine, Nara (Wikimedia Commons, CC BY-SA)
		To use your own photo: upload to /public/images/hero.jpg and change src to "/images/hero.jpg"
		-mt-4 cancels the header's mb-4 so the image sits flush against the nav.
	-->
	<section class="-mx-4 sm:-mx-8 -mt-4 relative mb-14 overflow-hidden">
		<img
			src="https://commons.wikimedia.org/wiki/Special:FilePath/20100716_Nara_Kasuga-taisha_2196.jpg"
			alt="Kasuga Taisha shrine, Nara, Japan"
			width="1280"
			height="420"
			class="w-full object-cover"
			style="height: 420px; object-position: center 40%;"
		/>
		<div
			class="absolute inset-0 flex items-end"
			style="background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.22) 55%, rgba(0,0,0,0.06) 100%);"
		>
			<div class="w-full p-6 sm:p-10">
				<p class="mb-2 font-mono text-xs uppercase tracking-widest text-white/60">
					14–18 September 2026 · NAIST, Nara, Japan
				</p>
				<h1 class="mb-1 text-2xl font-bold leading-snug text-white sm:text-3xl">
					1st German-Japanese Summer School
				</h1>
				<p class="text-base font-semibold text-white/90 sm:text-xl">
					Human-Centred Perception Modelling in XR
				</p>
			</div>
		</div>
	</section>

	<!-- ── ABOUT ─────────────────────────────────────────────────────────── -->
	<section class="mb-14">
		<p class="leading-relaxed">
			A five-day intensive research workshop bringing together Master's and PhD students from Japan
			and Germany to explore cutting-edge topics in extended reality, perception modelling, and AI.
			Hosted by CARE Lab &amp; IMD Lab at NAIST in collaboration with the LAVIS Lab at HSRM,
			Germany.
		</p>
		<p class="text-muted mt-3 text-sm">
			Participation is free of charge. · Enquiries: <a
				class="cactus-link"
				href="mailto:marquardt@ieee.org">marquardt@ieee.org</a
			>
		</p>
	</section>

	<!-- ── PROGRAMME STAGES ──────────────────────────────────────────────── -->
	<section class="mb-14">
		<h2 class="title mb-6 text-xl">The Programme</h2>
		<div class="grid gap-3 sm:grid-cols-2">
			{
				stages.map(({ num, title, text }) => (
					<div class="border-muted rounded border p-4">
						<p class="text-accent mb-1 font-mono text-xs font-semibold">{num}</p>
						<h3 class="text-accent-2 mb-1 font-semibold">{title}</h3>
						<p class="text-muted text-sm leading-relaxed">{text}</p>
					</div>
				))
			}
		</div>
		<p class="mt-4 text-sm">
			<a class="cactus-link" href="/programme/">Full schedule →</a>
		</p>
	</section>

	<!-- ── LECTURE TOPICS ────────────────────────────────────────────────── -->
	<section class="mb-14">
		<h2 class="title mb-4 text-xl">Topics Covered</h2>
		<div class="flex flex-wrap gap-2">
			{topics.map((t) => <span class="border-muted rounded-full border px-4 py-1.5 text-sm">{t}</span>)}
		</div>
	</section>

	<!-- ── VENUE & LOCATION ──────────────────────────────────────────────── -->
	<section class="mb-14">
		<h2 class="title mb-5 text-xl">Venue &amp; Location</h2>
		<div class="mb-5 grid gap-3 sm:grid-cols-2">
			<figure>
				<div class="overflow-hidden rounded-lg">
					<!-- Replace: upload a NAIST campus photo to /public/images/naist.jpg → src="/images/naist.jpg" -->
					<img
						src="https://commons.wikimedia.org/wiki/Special:FilePath/Kofukuji_Pagoda_2011.jpg"
						alt="Kofuku-ji Five-Story Pagoda, Nara — near NAIST"
						width="800"
						height="190"
						class="w-full object-cover"
						style="height: 190px; object-position: center 30%;"
					/>
				</div>
				<figcaption class="text-muted mt-1.5 text-xs">
					NAIST, Ikoma, Nara Prefecture ·
					<a
						class="cactus-link"
						href="https://www.naist.jp/en/"
						target="_blank"
						rel="noreferrer noopener">naist.jp</a
					>
				</figcaption>
			</figure>
			<figure>
				<div class="overflow-hidden rounded-lg">
					<!-- Replace: upload an excursion photo to /public/images/excursion.jpg → src="/images/excursion.jpg" -->
					<img
						src="https://commons.wikimedia.org/wiki/Special:FilePath/20100716_Nara_Kasuga-taisha_2196.jpg"
						alt="Kasuga Taisha shrine, Nara — Day 4 excursion area"
						width="800"
						height="190"
						class="w-full object-cover"
						style="height: 190px; object-position: center 50%;"
					/>
				</div>
				<figcaption class="text-muted mt-1.5 text-xs">
					Day 4 Excursion — Nara / Kyoto area ·
					<a class="cactus-link" href="/activities/">Details →</a>
				</figcaption>
			</figure>
		</div>
		<p class="text-muted text-sm leading-relaxed">
			The summer school takes place at NAIST (Nara Institute of Science and Technology) in Ikoma,
			Nara Prefecture — easily accessible from Osaka and Kyoto. The Nara region is home to
			UNESCO World Heritage temples, ancient shrines, and scenic countryside.
		</p>
	</section>

	<!-- ── PARTNERS / CONTACT ────────────────────────────────────────────── -->
	<section class="border-muted rounded border p-5 text-sm">
		<p class="text-muted leading-relaxed">
			Hosted by <strong class="text-global-text">CARE Lab &amp; IMD Lab</strong>, Nara Institute
			of Science and Technology (NAIST), Japan · in collaboration with
			<strong class="text-global-text">LAVIS Lab</strong>, Hochschule RheinMain (HSRM), Germany.
		</p>
	</section>
</PageLayout>
