			<figure>
				<div class="overflow-hidden rounded-lg">
					<!-- Replace: upload a Nara/Kyoto excursion photo to /public/images/nara-excursion.jpg -->
					<img
						src="https://images.unsplash.com/photo-1528360983277-13d401cdc186?auto=format&fit=crop&w=800&q=80"
						alt="Nara deer park — Day 4 excursion area"
						width="800"
						height="190"
						class="w-full object-cover"
						style="height: 190px; object-position: center 65%;"
					/>
				</div>
				<figcaption class="text-muted mt-1.5 text-xs">
					Day 4 Excursion — Nara / Kyoto area
				</figcaption>
			</figure>
		</div>
		<p class="text-muted text-sm leading-relaxed">
			The summer school takes place at NAIST (Nara Institute of Science and Technology) in Ikoma,
			Nara Prefecture — easily accessible from Osaka and Kyoto. The Nara region is famous for its
			UNESCO World Heritage temples, deer park, and scenic countryside, providing a unique setting
			for a cross-cultural research experience.
		</p>
	</section>

	<!-- ── LECTURE TOPICS ────────────────────────────────────────────────── -->
	<section class="mb-14">
		<h2 class="title mb-5 text-xl">Lecture Topics</h2>
		<div class="flex flex-wrap gap-2">
			{
				topics.map((t) => (
					<span class="border-muted rounded-full border px-4 py-1.5 text-sm">{t}</span>
				))
			}
		</div>
	</section>

	<!-- ── WHO / TAKE AWAY ───────────────────────────────────────────────── -->
	<section class="mb-14 grid gap-8 sm:grid-cols-2">
		<div>
			<h2 class="title mb-4 text-xl">Who Should Apply</h2>
			<ul class="space-y-1">
				{
					applyItems.map((a) => (
						<li class="text-muted flex items-start gap-2 text-sm">
							<span class="text-accent mt-0.5 shrink-0">—</span>
							<span>{a}</span>
						</li>
					))
				}
			</ul>
		</div>
		<div>
			<h2 class="title mb-4 text-xl">What You Take Away</h2>
			<ul class="space-y-1">
				{
					takeawayItems.map((t) => (
						<li class="text-muted flex items-start gap-2 text-sm">
							<span class="text-accent mt-0.5 shrink-0">—</span>
							<span>{t}</span>
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<!-- ── ACTIVITIES & EXCURSION ────────────────────────────────────────── -->
	<section class="mb-14">
		<h2 class="title mb-5 text-xl">Activities &amp; Excursion</h2>

		<!-- Wide image banner for the excursion -->
		<!-- Replace: upload your own excursion destination photo to /public/images/excursion.jpg -->
		<div class="-mx-4 sm:-mx-8 relative mb-5 overflow-hidden">
			<img
				src="https://images.unsplash.com/photo-1528360983277-13d401cdc186?auto=format&fit=crop&w=1400&q=80"
				alt="Nara Park — Day 4 guided excursion"
				width="1400"
				height="200"
				class="w-full object-cover"
				style="height: 210px; object-position: center 75%;"
			/>
			<div
				class="absolute inset-0 flex items-center px-6 sm:px-10"
				style="background: linear-gradient(to right, rgba(0,0,0,0.70) 0%, rgba(0,0,0,0.35) 60%, transparent 100%);"
			>
				<div>
					<p class="font-semibold text-white">Day 4 — Full-Day Excursion</p>
					<p class="text-sm text-white/80">
						Guided trip to the Nara / Kyoto area (tentative destination)
					</p>
				</div>
			</div>
		</div>

		<div class="grid gap-4 sm:grid-cols-2">
			<div class="border-muted rounded border p-4">
				<h3 class="text-accent-2 mb-2 font-semibold">Welcome Dinner</h3>
				<p class="text-muted text-sm leading-relaxed">
					Informal dinner with faculty and fellow participants on Tuesday evening — a chance to
					connect across institutions.
				</p>
			</div>
			<div class="border-muted rounded border p-4">
				<h3 class="text-accent-2 mb-2 font-semibold">Cross-Cultural Teams</h3>
				<p class="text-muted text-sm leading-relaxed">
					Work in interdisciplinary groups with students from Japan and Germany throughout the
					five-day programme.
				</p>
			</div>
		</div>
	</section>

	<!-- ── PARTNERS ──────────────────────────────────────────────────────── -->
