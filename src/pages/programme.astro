---
import PageLayout from "@/layouts/Base.astro";

const days = [
	{
		label: "Day 1",
		date: "Monday, 14 September",
		theme: "Expert Input",
		excursion: false,
		slots: [
			{ time: "9:00 – 9:45",   title: "Welcome and Introduction",                      detail: "Opening remarks and programme overview." },
			{ time: "9:45 – 10:30",  title: "Lecture 1 — Modelling Visual Attention",         detail: "" },
			{ time: "10:45 – 11:30", title: "Lecture 2 — Multisensory Perception and Integration", detail: "" },
			{ time: "11:30 – 12:15", title: "Lecture 3 — Vision Augmentation in XR",          detail: "" },
			{ time: "13:30 – 14:15", title: "Lecture 4 — Human-Machine Interaction",          detail: "" },
			{ time: "14:15 – 15:00", title: "Lecture 5 — Comfort Intelligence for HRI",       detail: "" },
			{ time: "15:15 – 16:45", title: "Workshop 1 — Design Thinking",                   detail: "" },
			{ time: "Evening",       title: "Group Finding",                                   detail: "" },
		],
	},
	{
		label: "Day 2",
		date: "Tuesday, 15 September",
		theme: "Research Ideation",
		excursion: false,
		slots: [
			{ time: "9:00 – 10:30",  title: "Workshop 2 — Ideation Workshop",        detail: "Forming cross-cultural research teams." },
			{ time: "10:45 – 12:15", title: "Literature Review",                      detail: "Guided team literature review session." },
			{ time: "13:30 – 16:00", title: "Concepts and Design",                    detail: "Team-based conceptual design and planning." },
			{ time: "16:00 – 16:45", title: "Group Presentation and Q&A",             detail: "" },
			{ time: "Evening",       title: "Welcome Dinner",                          detail: "Informal dinner with faculty and all participants." },
		],
	},
	{
		label: "Day 3",
		date: "Wednesday, 16 September",
		theme: "Prototype and Test",
		excursion: false,
		slots: [
			{ time: "9:00 – 10:30",  title: "Lecture 6 — Designing User Studies",    detail: "" },
			{ time: "10:45 – 12:15", title: "Research Question and Study Design",     detail: "Define your research question and plan the study approach." },
			{ time: "13:30 – 16:45", title: "Prototype and Refinement",               detail: "Iterative prototyping with peer and faculty feedback." },
		],
	},
	{
		label: "Day 4",
		date: "Thursday, 17 September",
		theme: "Excursion",
		excursion: true,
		slots: [],
	},
	{
		label: "Day 5",
		date: "Friday, 18 September",
		theme: "Share and Go Further",
		excursion: false,
		slots: [
			{ time: "9:00 – 12:15", title: "Final Presentations", detail: "Each group presents their results and research outcomes." },
			{ time: "13:30 – 15:00", title: "Closing Session",    detail: "Reflections, next steps, and farewell." },
		],
	},
];
---

<PageLayout
	meta={{
		title: "Programme",
		description:
			"Full schedule, activities, and venue information for the 1st German-Japanese Summer School on Human-Centred Perception Modelling in XR, 14–18 September 2026.",
	}}
>
	<!-- ── PAGE BANNER ───────────────────────────────────────────────────── -->
	<!--
		Banner image: Kasuga Taisha shrine path, Nara (Wikimedia Commons, CC BY-SA).
		Replace with own photo: upload to /public/images/programme-banner.jpg
	-->
	<section class="-mx-4 sm:-mx-8 -mt-4 relative mb-12 overflow-hidden">
		<img
			src="https://commons.wikimedia.org/wiki/Special:FilePath/20100716_Nara_Kasuga-taisha_2196.jpg"
			alt="Kasuga Taisha shrine path, Nara"
			width="1280"
			height="220"
			class="w-full object-cover"
			style="height: 220px; object-position: center 45%;"
		/>
		<div
			class="absolute inset-0 flex items-end"
			style="background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.0) 70%);"
		>
			<div class="w-full p-5 sm:p-8">
				<h1 class="text-2xl font-bold text-white">Programme</h1>
				<p class="mt-1 text-sm text-white/70">
					14–18 September 2026, NAIST, Nara, Japan. All times tentative.
				</p>
			</div>
		</div>
	</section>

	<!-- ── SCHEDULE ──────────────────────────────────────────────────────── -->
	<div class="mb-16 space-y-10">
		{
			days.map(({ label, date, theme, excursion, slots }) => (
				<section>
					<div class="mb-3 flex flex-wrap items-baseline gap-x-3 gap-y-1">
						<span class="text-accent font-mono text-xs font-semibold uppercase">{label}</span>
						<h2 class="text-accent-2 font-semibold">{date}</h2>
						<span class="text-muted text-xs">{theme}</span>
					</div>

					{excursion ? (
						<div class="border-muted rounded border p-5">
							<h3 class="text-accent-2 mb-1 font-semibold">Guided Full-Day Excursion</h3>
							<p class="text-muted text-sm leading-relaxed">
								Tentatively Koyasan (高野山), one of Japan's most sacred Buddhist mountain
								settlements. Final destination confirmed closer to the event.
							</p>
						</div>
					) : (
						<div class="border-muted divide-muted divide-y rounded border">
							{slots.map(({ time, title, detail }) => (
								<div class="flex gap-4 px-4 py-3 text-sm">
									<span class="text-muted w-32 shrink-0 font-mono text-xs leading-6">{time}</span>
									<div class="leading-relaxed">
										<span class="font-medium">{title}</span>
										{detail && <span class="text-muted"> — {detail}</span>}
									</div>
								</div>
							))}
						</div>
					)}
				</section>
			))
		}
	</div>

	<!-- ── SOCIAL ACTIVITIES ─────────────────────────────────────────────── -->
	<section class="mb-16">
		<h2 class="title mb-6 text-xl">Social Activities</h2>

		<h3 class="text-accent-2 mb-1 font-semibold">Welcome Dinner</h3>
		<p class="text-muted mb-6 text-sm leading-relaxed">
			An informal dinner with faculty and all participants on Tuesday evening (Day 2). A chance to
			connect across institutions before the collaborative work begins.
		</p>

		<h3 class="text-accent-2 mb-1 font-semibold">Cross-Cultural Research Teams</h3>
		<p class="text-muted text-sm leading-relaxed">
			Throughout the week, participants work in interdisciplinary groups mixing students from Japan
			and Germany. Teams form on Day 1 and collaborate on a joint research project presented on the
			final day.
		</p>
	</section>

	<!-- ── VENUE AND LOCATION ────────────────────────────────────────────── -->
	<section class="mb-16">
		<h2 class="title mb-6 text-xl">Venue and Location</h2>

		<div class="mb-5 grid gap-3 sm:grid-cols-2">
			<figure>
				<div class="overflow-hidden rounded-lg">
					<!--
						Replace with own campus photo: upload to /public/images/naist-campus.jpg
					-->
					<img
						src="https://www.naist.jp/mt-static/support/theme_static/naist_en_main/images/facilities/facilities_cover2.jpg"
						alt="NAIST campus facilities, Ikoma, Nara"
						width="800"
						height="190"
						class="w-full object-cover"
						style="height: 190px; object-position: center 50%;"
					/>
				</div>
				<figcaption class="text-muted mt-1.5 text-xs">
					NAIST campus, Ikoma, Nara Prefecture
				</figcaption>
			</figure>
			<figure>
				<div class="overflow-hidden rounded-lg">
					<img
						src="https://www.naist.jp/en/toppage-banner/img/main_entrance.png"
						alt="NAIST main entrance"
						width="800"
						height="190"
						class="w-full object-cover"
						style="height: 190px; object-position: center 60%;"
					/>
				</div>
				<figcaption class="text-muted mt-1.5 text-xs">
					NAIST main entrance
				</figcaption>
			</figure>
		</div>

		<p class="text-muted mb-4 text-sm leading-relaxed">
			The summer school takes place at <strong class="text-global-text">Nara Institute of Science
			and Technology (NAIST)</strong>, 8916-5 Takayama-cho, Ikoma, Nara 630-0192, Japan. NAIST is
			located in Ikoma, Nara Prefecture, approximately 30 minutes from central Osaka and 50 minutes
			from Kyoto by train.
		</p>

		<h3 class="text-accent-2 mb-1 mt-6 font-semibold">Rooms</h3>
		<p class="text-muted text-sm leading-relaxed">
			Lecture hall and workshop rooms to be confirmed. Details will be shared with registered
			participants before the event.
		</p>

		<h3 class="text-accent-2 mb-1 mt-6 font-semibold">Getting There</h3>
		<p class="text-muted text-sm leading-relaxed">
			From Osaka (Kintetsu Namba): take the Kintetsu Osaka line to Gakken-Nara-Tomigaoka Station
			(approx. 25 min), then a short shuttle bus or taxi to NAIST. From Kyoto Station: take the
			Kintetsu Kyoto line to Yamato-Saidaiji, transfer to Gakken-Nara-Tomigaoka (approx. 50 min
			total). A campus shuttle runs from the station during the event.
		</p>
	</section>

	<!-- ── FACULTY NOTE ──────────────────────────────────────────────────── -->
	<section class="text-muted text-sm">
		<p class="leading-relaxed">
			Lectures and workshops are delivered by researchers from CARE Lab and IMD Lab (NAIST) and the
			LAVIS Lab (HSRM, Germany). See <a class="cactus-link" href="/organisers/">Organisers</a> for
			faculty details.
		</p>
	</section>
