---
import PageLayout from "@/layouts/Base.astro";

/*
  Organiser photos must be uploaded to /public/images/organisers/ in the repository.
  Photos are in your workspace folder → organiser-photos/
  Upload each file to: public/images/organisers/<filename>
*/

const naist = {
	address: "Nara Institute of Science and Technology · 8916-5 Takayama-cho, Ikoma, Nara 630-0192",
	labs: [
		{
			lab: "CARE Lab",
			members: [
				{
					title: "Dr.",
					name: "Alexander Marquardt",
					photo: "/images/organisers/alexander-marquardt.png",
				},
				{
					title: "Asst. Prof.",
					name: "Monica Perusquia",
					photo: "/images/organisers/monica-perusquia.jpg",
				},
			],
		},
		{
			lab: "IMD Lab",
			members: [
				{
					title: "Assoc. Prof.",
					name: "Taishi Sawabe",
					photo: "/images/organisers/taishi-sawabe.jpg",
				},
				{
					title: "Asst. Prof.",
					name: "Isidro Butaslac",
					photo: "/images/organisers/isidro-butaslac.png",
				},
			],
		},
	],
};

const hsrm = {
	address: "Hochschule RheinMain · Kurt-Schumacher-Ring 18, 65197 Wiesbaden, Germany",
	labs: [
		{
			lab: "LAVIS Lab",
			members: [
				{
					title: "Prof.",
					name: "Dirk Voelz",
					photo: "/images/organisers/dirk-voelz.png",
				},
				{
					title: "Prof.",
					name: "Martin Weier",
					photo: "/images/organisers/martin-weier.jpg",
				},
				{
					title: "Prof.",
					name: "Biying Fu",
					photo: "/images/organisers/biying-fu.png",
				},
			],
		},
	],
};
---

<PageLayout
	meta={{
		title: "Organisers",
		description: "Faculty and organisers of the 1st German-Japanese Summer School on HCPM in XR.",
	}}
>
	<!-- ── PAGE BANNER ───────────────────────────────────────────────────── -->
	<!--
		Banner image: NAIST facilities (official NAIST photo).
		Replace with own photo: upload to /public/images/organisers-banner.jpg
	-->
	<section class="-mx-4 sm:-mx-8 -mt-4 relative mb-12 overflow-hidden">
		<img
			src="https://www.naist.jp/mt-static/support/theme_static/naist_en_main/images/facilities/facilities_cover2.jpg"
			alt="NAIST campus facilities, Nara"
			width="1280"
			height="220"
			class="w-full object-cover"
			style="height: 220px; object-position: center 50%;"
		/>
		<div
			class="absolute inset-0 flex items-end"
			style="background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.0) 70%);"
		>
			<div class="w-full p-5 sm:p-8">
				<h1 class="text-2xl font-bold text-white">Organisers</h1>
				<p class="mt-1 text-sm text-white/70">NAIST, Japan · HSRM, Germany</p>
			</div>
		</div>
	</section>

	<!-- ── NAIST ─────────────────────────────────────────────────────────── -->
	<section class="mb-12">
		<h2 class="title mb-1 text-xl">NAIST, Japan</h2>
		<p class="text-muted mb-8 text-sm">{naist.address}</p>

		{
			naist.labs.map(({ lab, members }) => (
				<div class="mb-8">
					<p class="text-accent mb-4 font-mono text-xs font-semibold uppercase">{lab}</p>
					<div class="grid gap-6 sm:grid-cols-2">
						{members.map(({ title, name, photo }) => (
							<div class="flex items-center gap-4">
								<img
									src={photo}
									alt={name}
									width="80"
									height="80"
									class="h-20 w-20 shrink-0 rounded-full object-cover"
								/>
								<div>
									<p class="text-accent font-mono text-xs">{title}</p>
									<h3 class="text-accent-2 font-semibold">{name}</h3>
									<p class="text-muted text-sm">{lab}, NAIST</p>
								</div>
							</div>
						))}
					</div>
				</div>
			))
		}
	</section>

	<!-- ── HSRM ──────────────────────────────────────────────────────────── -->
	<section class="mb-12">
		<h2 class="title mb-1 text-xl">HSRM, Germany</h2>
		<p class="text-muted mb-8 text-sm">{hsrm.address}</p>

		{
			hsrm.labs.map(({ lab, members }) => (
				<div class="mb-8">
					<p class="text-accent mb-4 font-mono text-xs font-semibold uppercase">{lab}</p>
					<div class="grid gap-6 sm:grid-cols-3">
						{members.map(({ title, name, photo }) => (
							<div class="flex flex-col items-center text-center">
								<img
									src={photo}
									alt={name}
									width="80"
									height="80"
									class="mb-3 h-20 w-20 rounded-full object-cover"
								/>
								<p class="text-accent font-mono text-xs">{title}</p>
								<h3 class="text-accent-2 font-semibold text-sm">{name}</h3>
								<p class="text-muted text-xs">{lab}, HSRM</p>
							</div>
						))}
					</div>
				</div>
			))
		}
	</section>

	<!-- ── CONTACT ───────────────────────────────────────────────────────── -->
	<section class="text-muted text-sm">
		<p class="leading-relaxed">
			For enquiries about the summer school, contact <a
				class="cactus-link"
				href="mailto:marquardt@ieee.org">marquardt@ieee.org</a
			>.
		</p>
	</section>
</PageLayout>
