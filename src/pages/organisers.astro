---
import PageLayout from "@/layouts/Base.astro";

/*
  Photos must be uploaded to /public/images/organisers/ in the repository.
  Files are in your workspace folder under organiser-photos/.
*/

const naist = {
	address: "Nara Institute of Science and Technology, 8916-5 Takayama-cho, Ikoma, Nara 630-0192",
	labs: [
		{
			lab: "CARE Lab",
			members: [
				{
					title: "Dr.-Eng.",
					name: "Alexander Marquardt",
					photo: "/images/organisers/alexander-marquardt.png",
					bio: "is a JSPS Postdoctoral Fellow at the Nara Institute of Science and Technology in Japan. He received his MSc from Bonn-Rhein-Sieg University of Applied Sciences and his PhD in Computer Science from the University of Bremen in Germany. His research focuses on developing multisensory user interfaces that enhance interaction and perception in XR environments, aiming to improve user experience and system effectiveness. Alexander also explores the integration of AI technologies into immersive experiences, particularly how language models can enable more intuitive and context-aware interactions in virtual environments.",
				},
				{
					title: "Assistant Professor",
					name: "Monica Perusquia",
					photo: "/images/organisers/monica-perusquia.jpg",
					bio: "is an Assistant Professor at the Computational Augmented Reality Engineering Lab (CARE Lab) at NAIST, Japan. Her research focuses on augmented and extended reality interfaces, human perception in immersive environments, and the design of interaction techniques that bridge the physical and digital worlds. [Bio to be updated.]",
				},
			],
		},
		{
			lab: "IMD Lab",
			members: [
				{
					title: "Associate Professor",
					name: "Taishi Sawabe",
					photo: "/images/organisers/taishi-sawabe.jpg",
					bio: "is an Associate Professor at the Interactive Media Design Lab (IMD Lab) at NAIST, Japan. His research explores the design of interactive media systems with a focus on human-computer interaction, haptic feedback, and user experience in virtual and augmented environments. [Bio to be updated.]",
				},
				{
					title: "Assistant Professor",
					name: "Isidro Butaslac",
					photo: "/images/organisers/isidro-butaslac.png",
					bio: "is an Assistant Professor at the Interactive Media Design Lab (IMD Lab) at NAIST, Japan. His research interests include human-robot interaction, social robotics, and the design of intelligent interactive systems for collaborative and immersive settings. [Bio to be updated.]",
				},
			],
		},
	],
};

const hsrm = {
	address: "Hochschule RheinMain, Kurt-Schumacher-Ring 18, 65197 Wiesbaden, Germany",
	labs: [
		{
			lab: "LAVIS Lab",
			members: [
				{
					title: "Professor",
					name: "Dirk Voelz",
					photo: "/images/organisers/dirk-voelz.png",
					bio: "is a Professor in the Faculty of Design, Computer Science, Media at Hochschule RheinMain, Germany. His research interests include real-time rendering, visual perception, and image quality assessment for immersive display systems. He leads the LAVIS Lab and supervises projects at the intersection of computer graphics and perceptual science. [Bio to be updated.]",
				},
				{
					title: "Professor",
					name: "Martin Weier",
					photo: "/images/organisers/martin-weier.jpg",
					bio: "is a full professor for visual computing at the Hochschule RheinMain in Wiesbaden, Germany. He received his MSc in Computer Science from the Bonn-Rhein-Sieg University Sankt Augustin and his PhD from Saarland University, Germany. His research interests include perception and gaze-contingent rendering where he published a series of papers that deal with perception-driven techniques and gaze-contingent ray tracing systems in head-mounted displays. Martin's other research interests include visual analytics, high-quality rendering approaches, compiler technologies, and virtual and augmented reality display systems.",
				},
				{
					title: "Professor",
					name: "Biying Fu",
					photo: "/images/organisers/biying-fu.png",
					bio: "is currently a full professor at RheinMain University of Applied Sciences in the Faculty of Design, Computer Science, Media, focusing on explainable AI and improving human-computer interaction. Previously, she worked as senior research scientist in the Smart Living and Biometric Technologies department at the Fraunhofer Institute for Computer Graphics Research, primarily developing algorithms for indoor localization and activity recognition. She completed her PhD in 2020 on Sensor Applications for Human Activity Recognition in Smart Environments. Her research interests are in data processing, quality assurance for biometrics, machine learning, and artificial intelligence.",
				},
			],
		},
	],
};
---

<PageLayout
	meta={{
		title: "Organisers",
		description: "Faculty and organisers of the 1st German-Japanese Summer School on HCPM in XR.",
	}}
>
	<!-- ── PAGE BANNER ───────────────────────────────────────────────────── -->
	<section class="-mx-4 sm:-mx-8 -mt-4 relative mb-12 overflow-hidden">
		<img
			src="https://www.naist.jp/mt-static/support/theme_static/naist_en_main/images/facilities/facilities_cover2.jpg"
			alt="NAIST campus facilities, Nara"
			width="1280"
			height="220"
			class="w-full object-cover"
			style="height: 220px; object-position: center 50%;"
		/>
		<div
			class="absolute inset-0 flex items-end"
			style="background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.0) 70%);"
		>
			<div class="w-full p-5 sm:p-8">
				<h1 class="text-2xl font-bold text-white">Organisers</h1>
				<p class="mt-1 text-sm text-white/70">NAIST, Japan and HSRM, Germany</p>
			</div>
		</div>
	</section>

	<!-- ── NAIST ─────────────────────────────────────────────────────────── -->
	<section class="mb-14">
		<h2 class="title mb-1 text-xl">NAIST, Japan</h2>
		<p class="text-muted mb-8 text-sm">{naist.address}</p>

		{naist.labs.map(({ lab, members }) => (
			<div class="mb-10">
				<p class="text-accent mb-5 font-mono text-xs font-semibold uppercase">{lab}</p>
				<div class="space-y-8">
					{members.map(({ title, name, photo, bio }) => (
						<div class="flex gap-5">
							<img
								src={photo}
								alt={name}
								width="80"
								height="80"
								class="mt-1 h-20 w-20 shrink-0 rounded-full object-cover"
							/>
							<div>
								<p class="text-muted mb-0.5 text-xs">{title}</p>
								<h3 class="text-accent-2 mb-0.5 font-semibold">{name}</h3>
								<p class="text-accent mb-2 font-mono text-xs uppercase">{lab}, NAIST</p>
								<p class="text-muted text-sm leading-relaxed">
									<strong class="text-global-text">{name.split(" ")[0]}</strong> {bio}
								</p>
							</div>
						</div>
					))}
				</div>
			</div>
		))}
	</section>

	<!-- ── HSRM ──────────────────────────────────────────────────────────── -->
	<section class="mb-14">
		<h2 class="title mb-1 text-xl">HSRM, Germany</h2>
		<p class="text-muted mb-8 text-sm">{hsrm.address}</p>

		{hsrm.labs.map(({ lab, members }) => (
			<div class="mb-10">
				<p class="text-accent mb-5 font-mono text-xs font-semibold uppercase">{lab}</p>
				<div class="space-y-8">
					{members.map(({ title, name, photo, bio }) => (
						<div class="flex gap-5">
							<img
								src={photo}
								alt={name}
								width="80"
								height="80"
								class="mt-1 h-20 w-20 shrink-0 rounded-full object-cover"
							/>
							<div>
								<p class="text-muted mb-0.5 text-xs">{title}</p>
								<h3 class="text-accent-2 mb-0.5 font-semibold">{name}</h3>
								<p class="text-accent mb-2 font-mono text-xs uppercase">{lab}, HSRM</p>
								<p class="text-muted text-sm leading-relaxed">
									<strong class="text-global-text">{name.split(" ")[0]}</strong> {bio}
								</p>
							</div>
						</div>
					))}
				</div>
			</div>
		))}
	</section>

	<!-- ── CONTACT ───────────────────────────────────────────────────────── -->
	<section class="text-muted text-sm">
		<p class="leading-relaxed">
			For enquiries about the summer school, contact <a
				class="cactus-link"
				href="mailto:marquardt@ieee.org">marquardt@ieee.org</a
			>.
		</p>
	</section>
</PageLayout>
