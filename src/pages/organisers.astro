---
import PageLayout from "@/layouts/Base.astro";

const naist = [
	{ lab: "CARE Lab", name: "Name Surname", role: "Role / Position" },
	{ lab: "IMD Lab", name: "Name Surname", role: "Role / Position" },
	{ lab: "IMD Lab", name: "Name Surname", role: "Role / Position" },
];

const hsrm = [
	{ lab: "LAVIS Lab", name: "Prof. Martin Weier", role: "Professor, Laboratory for Visual Computing and Simulation" },
	{ lab: "LAVIS Lab", name: "Name Surname", role: "Role / Position" },
];
---

<PageLayout
	meta={{
		title: "Organisers",
		description: "Faculty and organisers of the 1st German-Japanese Summer School on HCPM in XR.",
	}}
>
	<h1 class="title mb-12 text-2xl">Organisers</h1>

	<!-- NAIST -->
	<section class="mb-12">
		<h2 class="title mb-1 text-xl">NAIST, Japan</h2>
		<p class="text-muted mb-6 text-sm">
			Nara Institute of Science and Technology · 8916-5 Takayama-cho, Ikoma, Nara 630-0192
		</p>
		<div class="grid gap-4 sm:grid-cols-2">
			{
				naist.map(({ lab, name, role }) => (
					<div class="border-muted rounded border p-4">
						<p class="text-accent mb-1 font-mono text-xs font-semibold uppercase">{lab}</p>
						<h3 class="text-accent-2 mb-1 font-semibold">{name}</h3>
						<p class="text-muted text-sm">{role}</p>
					</div>
				))
			}
		</div>
	</section>

	<!-- HSRM -->
	<section class="mb-12">
		<h2 class="title mb-1 text-xl">HSRM, Germany</h2>
		<p class="text-muted mb-6 text-sm">
			Hochschule RheinMain · Kurt-Schumacher-Ring 18, 65197 Wiesbaden
		</p>
		<div class="grid gap-4 sm:grid-cols-2">
			{
				hsrm.map(({ lab, name, role }) => (
					<div class="border-muted rounded border p-4">
						<p class="text-accent mb-1 font-mono text-xs font-semibold uppercase">{lab}</p>
						<h3 class="text-accent-2 mb-1 font-semibold">{name}</h3>
						<p class="text-muted text-sm">{role}</p>
					</div>
				))
			}
		</div>
	</section>

	<!-- Contact -->
	<section class="border-muted rounded border p-5 text-sm">
		<h2 class="text-accent-2 mb-2 font-semibold">Contact</h2>
		<p class="text-muted leading-relaxed">
			For enquiries about the summer school, please contact us at <a
				class="cactus-link"
				href="mailto:kiyo@is.naist.jp">kiyo@is.naist.jp</a
			>.
		</p>
	</section>
</PageLayout>
